# Google Sheets API – service account JSON (single line, escaped)
GOOGLE_SERVICE_ACCOUNT_CREDENTIALS={"type":"service_account","project_id":"..."}

# Main spreadsheet ID (from the sheet URL)
MAIN_SHEET_ID=your_main_sheet_id

# Gemini API key (optional)
GEMINI_API_KEY=your_gemini_api_key

# --- Auth (NextAuth / Auth.js) ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=your_auth_secret

# Google OAuth 2.0 credentials (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Full site URL (used by NextAuth for callback URLs)
AUTH_URL=https://sheet.hntgaming.me
